<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- ================================================================
         Séquence — AT0001, AT0002…
    ================================================================ -->
    <record id="seq_assistance_ticket" model="ir.sequence">
        <field name="name">Ticket d'assistance</field>
        <field name="code">assistance.ticket</field>
        <field name="prefix">AT</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- ================================================================
         Équipes par défaut
    ================================================================ -->
    <record id="team_rh" model="assistance.team">
        <field name="name">Ressources Humaines</field>
        <field name="description">Questions RH, congés, paie…</field>
        <field name="privacy_visibility">portal</field>
    </record>

    <record id="team_it" model="assistance.team">
        <field name="name">Informatique</field>
        <field name="description">Support technique et matériel</field>
        <field name="privacy_visibility">portal</field>
    </record>

    <!-- ================================================================
         Étapes par défaut
    ================================================================ -->
    <record id="stage_new" model="assistance.stage">
        <field name="name">Nouveau</field>
        <field name="sequence">1</field>
        <field name="is_closed" eval="False"/>
        <field name="fold" eval="False"/>
        <field name="team_ids" eval="[(4, ref('team_rh')), (4, ref('team_it'))]"/>
    </record>

    <record id="stage_in_progress" model="assistance.stage">
        <field name="name">En cours</field>
        <field name="sequence">2</field>
        <field name="is_closed" eval="False"/>
        <field name="fold" eval="False"/>
        <field name="team_ids" eval="[(4, ref('team_rh')), (4, ref('team_it'))]"/>
    </record>

    <record id="stage_waiting" model="assistance.stage">
        <field name="name">En attente</field>
        <field name="sequence">3</field>
        <field name="is_closed" eval="False"/>
        <field name="fold" eval="True"/>
        <field name="team_ids" eval="[(4, ref('team_rh')), (4, ref('team_it'))]"/>
    </record>

    <record id="stage_resolved" model="assistance.stage">
        <field name="name">Résolu</field>
        <field name="sequence">4</field>
        <field name="is_closed" eval="True"/>
        <field name="fold" eval="True"/>
        <field name="team_ids" eval="[(4, ref('team_rh')), (4, ref('team_it'))]"/>
    </record>

</odoo>
