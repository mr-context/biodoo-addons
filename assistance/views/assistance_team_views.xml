<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         assistance.team — liste
    ================================================================ -->
    <record id="view_assistance_team_list" model="ir.ui.view">
        <field name="name">assistance.team.list</field>
        <field name="model">assistance.team</field>
        <field name="arch" type="xml">
            <list string="Équipes">
                <field name="name"/>
                <field name="description"/>
                <field name="privacy_visibility" widget="badge" optional="show"/>
                <field name="member_ids" widget="many2many_tags" optional="show"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         assistance.team — formulaire
    ================================================================ -->
    <record id="view_assistance_team_form" model="ir.ui.view">
        <field name="name">assistance.team.form</field>
        <field name="model">assistance.team</field>
        <field name="arch" type="xml">
            <form string="Équipe">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nom de l'équipe"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="description"/>
                            <field name="manager_ids" widget="many2many_avatar_user"/>
                            <field name="privacy_visibility" widget="radio"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="status"
                         invisible="privacy_visibility != 'invited_internal'">
                        <i class="fa fa-info-circle me-1"/>
                        Mode <strong>Privé</strong> : seuls les membres listés ci-dessous
                        pourront voir les tickets de cette équipe.
                    </div>
                    <div class="alert alert-warning" role="status"
                         invisible="privacy_visibility != 'portal'">
                        <i class="fa fa-globe me-1"/>
                        Mode <strong>Portail activé</strong> : les utilisateurs portail
                        pourront soumettre des demandes à cette équipe depuis leur espace en ligne.
                    </div>
                    <notebook>
                        <page string="Membres" name="members">
                            <field name="member_ids" widget="many2many_tags"
                                   domain="[('share', '=', False)]"/>
                        </page>
                        <page string="Étapes" name="stages">
                            <field name="stage_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         Action principale
    ================================================================ -->
    <record id="action_assistance_team" model="ir.actions.act_window">
        <field name="name">Équipes</field>
        <field name="res_model">assistance.team</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
