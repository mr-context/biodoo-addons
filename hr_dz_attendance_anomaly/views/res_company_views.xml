<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_anomaly" model="ir.ui.view">
        <field name="name">res.company.form.anomaly.tolerance</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Pointage — tolérances anomalies">
                    <field name="late_tolerance_minutes"/>
                    <field name="early_tolerance_minutes"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>