<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Catégories Socio-Professionnelles
            Conformes à la Loi 90-11 relative aux relations de travail
        -->

        <record id="csp_cadre_dirigeant" model="hr.csp">
            <field name="name">Cadre Dirigeant</field>
            <field name="code">CD</field>
            <field name="sequence">1</field>
            <field name="description">Cadres ayant des responsabilités de direction générale</field>
        </record>

        <record id="csp_cadre" model="hr.csp">
            <field name="name">Cadre</field>
            <field name="code">C</field>
            <field name="sequence">2</field>
            <field name="description">Cadres techniques, administratifs ou commerciaux</field>
        </record>

        <record id="csp_maitrise" model="hr.csp">
            <field name="name">Maîtrise</field>
            <field name="code">M</field>
            <field name="sequence">3</field>
            <field name="description">Agents de maîtrise, techniciens supérieurs</field>
        </record>

        <record id="csp_execution" model="hr.csp">
            <field name="name">Exécution</field>
            <field name="code">E</field>
            <field name="sequence">4</field>
            <field name="description">Agents d'exécution, employés, ouvriers</field>
        </record>

    </data>
</odoo>
