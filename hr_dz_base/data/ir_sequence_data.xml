<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_hr_employee_matricule" model="ir.sequence">
            <field name="name">Matricule Employé</field>
            <field name="code">hr.employee.matricule</field>
            <field name="prefix">%(year)s</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_hr_attestation_travail" model="ir.sequence">
            <field name="name">Attestation de travail</field>
            <field name="code">hr.attestation.travail</field>
            <field name="prefix">AT/%(year)s/</field>
            <field name="padding">4</field>
        </record>

        <record id="seq_hr_certificat_travail" model="ir.sequence">
            <field name="name">Certificat de travail</field>
            <field name="code">hr.certificat.travail</field>
            <field name="prefix">CT/%(year)s/</field>
            <field name="padding">4</field>
        </record>

    </data>
</odoo>
