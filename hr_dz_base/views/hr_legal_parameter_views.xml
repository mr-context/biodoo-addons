<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="hr_legal_parameter_view_tree" model="ir.ui.view">
        <field name="name">hr.legal.parameter.tree</field>
        <field name="model">hr.legal.parameter</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="value"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="hr_legal_parameter_view_form" model="ir.ui.view">
        <field name="name">hr.legal.parameter.form</field>
        <field name="model">hr.legal.parameter</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="value"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Référence légale, décret..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="hr_legal_parameter_action" model="ir.actions.act_window">
        <field name="name">Paramètres légaux</field>
        <field name="res_model">hr.legal.parameter</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer un paramètre légal
            </p>
        </field>
    </record>

</odoo>
