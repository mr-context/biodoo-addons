<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Alerte fin période d'essai (7 jours avant) -->
        <record id="ir_cron_trial_period_alert" model="ir.cron">
            <field name="name">Contrats: Alerte fin période d'essai</field>
            <field name="model_id" ref="hr.model_hr_version"/>
            <field name="state">code</field>
            <field name="code">model._cron_trial_period_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- Alerte fin de contrat CDD (30 jours avant) -->
        <record id="ir_cron_contract_end_alert" model="ir.cron">
            <field name="name">Contrats: Alerte fin de contrat CDD</field>
            <field name="model_id" ref="hr.model_hr_version"/>
            <field name="state">code</field>
            <field name="code">model._cron_contract_end_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
