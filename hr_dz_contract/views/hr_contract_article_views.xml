<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================================
         ARTICLE DE CONTRAT
         ===================================================================== -->

    <!-- Article Form View -->
    <record id="hr_contract_article_view_form" model="ir.ui.view">
        <field name="name">hr.contract.article.form</field>
        <field name="model">hr.contract.article</field>
        <field name="arch" type="xml">
            <form string="Article de contrat">
                <header>
                    <button name="action_new_revision" type="object"
                            string="Nouvelle révision" class="btn-secondary"
                            invisible="not is_current"
                            groups="hr.group_hr_manager"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="toggle_active"
                                icon="fa-archive">
                            <field name="active" widget="boolean_button"
                                   options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nom de l'article"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Version">
                            <field name="is_current" readonly="1"/>
                            <field name="parent_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Validité">
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                    <separator string="Contenu de l'article"/>
                    <field name="content" nolabel="1"/>
                    <div class="alert alert-info" role="alert">
                        <strong>Placeholders disponibles:</strong><br/>
                        <code>[[civilite]]</code> <code>[[employe]]</code> <code>[[poste]]</code> <code>[[type_contrat]]</code><br/>
                        <code>[[date_debut]]</code> <code>[[date_fin]]</code> <code>[[salaire]]</code> <code>[[salaire_lettres]]</code><br/>
                        <code>[[duree_essai]]</code> <code>[[duree_preavis]]</code> <code>[[departement]]</code><br/>
                        <code>[[duree_contrat_mois]]</code> <code>[[societe]]</code> <code>[[adresse_societe]]</code><br/>
                        <code>[[nif]]</code> <code>[[nis]]</code> <code>[[rc]]</code>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Article List View -->
    <record id="hr_contract_article_view_list" model="ir.ui.view">
        <field name="name">hr.contract.article.list</field>
        <field name="model">hr.contract.article</field>
        <field name="arch" type="xml">
            <list string="Articles de contrat">
                <field name="code"/>
                <field name="name"/>
                <field name="is_current" string="Courant"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Article Search View -->
    <record id="hr_contract_article_view_search" model="ir.ui.view">
        <field name="name">hr.contract.article.search</field>
        <field name="model">hr.contract.article</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Version courante" name="filter_current" domain="[('is_current', '=', True)]"/>
                <filter string="Archivés" name="filter_inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Article Action -->
    <record id="hr_contract_article_action" model="ir.actions.act_window">
        <field name="name">Articles de contrat</field>
        <field name="res_model">hr.contract.article</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_current': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer un article de contrat
            </p>
            <p>
                Les articles sont des clauses réutilisables dans les modèles de contrat.
                Utilisez des placeholders comme [[employe]] ou [[salaire]] pour personnaliser le contenu.
            </p>
        </field>
    </record>

    <!-- =====================================================================
         MODELE DE CONTRAT
         ===================================================================== -->

    <!-- Modele Form View -->
    <record id="hr_contract_modele_view_form" model="ir.ui.view">
        <field name="name">hr.contract.modele.form</field>
        <field name="model">hr.contract.modele</field>
        <field name="arch" type="xml">
            <form string="Modèle de contrat">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="toggle_active"
                                icon="fa-archive">
                            <field name="active" widget="boolean_button"
                                   options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nom du modèle"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="contract_type_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Articles" name="articles">
                            <field name="article_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="article_id" options="{'no_create': True}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description" nolabel="1" placeholder="Description du modèle..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Modele List View -->
    <record id="hr_contract_modele_view_list" model="ir.ui.view">
        <field name="name">hr.contract.modele.list</field>
        <field name="model">hr.contract.modele</field>
        <field name="arch" type="xml">
            <list string="Modèles de contrat">
                <field name="name"/>
                <field name="contract_type_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Modele Action -->
    <record id="hr_contract_modele_action" model="ir.actions.act_window">
        <field name="name">Modèles de contrat</field>
        <field name="res_model">hr.contract.modele</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer un modèle de contrat
            </p>
            <p>
                Les modèles regroupent des articles (clauses) pour un type de contrat.
                Ex: "CDI Standard" avec articles engagement, durée, salaire, etc.
            </p>
        </field>
    </record>

</odoo>
