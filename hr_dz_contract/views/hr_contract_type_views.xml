<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Contract Type Tree View -->
    <record id="hr_contract_type_view_list" model="ir.ui.view">
        <field name="name">hr.contract.type.list</field>
        <field name="model">hr.contract.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="is_cdd"/>
                <field name="has_trial_period"/>
                <field name="default_trial_months"/>
                <field name="max_renewals"/>
                <field name="max_duration_months"/>
                <field name="cnas_reduction"/>
            </list>
        </field>
    </record>

    <!-- Contract Type Form View -->
    <record id="hr_contract_type_view_form" model="ir.ui.view">
        <field name="name">hr.contract.type.form</field>
        <field name="model">hr.contract.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nom du type de contrat"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Caractéristiques">
                            <field name="is_cdd"/>
                            <field name="is_renewable"/>
                            <field name="max_renewals" invisible="not is_renewable"/>
                            <field name="max_duration_months" invisible="not is_cdd"/>
                        </group>
                    </group>
                    <group>
                        <group string="Période d'essai">
                            <field name="has_trial_period"/>
                            <field name="default_trial_months" invisible="not has_trial_period"/>
                        </group>
                        <group string="Avantages">
                            <field name="cnas_reduction"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="hr_contract_type_action" model="ir.actions.act_window">
        <field name="name">Types de contrat</field>
        <field name="res_model">hr.contract.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
