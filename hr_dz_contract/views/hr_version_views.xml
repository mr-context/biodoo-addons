<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Contract (hr.version) List View -->
    <record id="hr_version_contract_view_list" model="ir.ui.view">
        <field name="name">hr.version.contract.list</field>
        <field name="model">hr.version</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <list string="Contrats" default_order="date_version desc"
                  decoration-muted="state == 'draft'"
                  decoration-info="state == 'pending'"
                  decoration-success="state == 'active'"
                  decoration-danger="state in ('expired', 'terminated')">
                <field name="employee_id"/>
                <field name="contract_type_id"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'draft'"
                       decoration-info="state == 'pending'"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'expired'"
                       decoration-danger="state == 'terminated'"/>
                <field name="job_id" optional="show"/>
                <field name="department_id" optional="hide"/>
                <field name="contract_date_start"/>
                <field name="contract_date_end" optional="show"/>
                <field name="trial_state" widget="badge"
                       decoration-info="trial_state == 'pending'"
                       decoration-warning="trial_state in ('ongoing', 'extended')"
                       decoration-success="trial_state == 'confirmed'"
                       decoration-danger="trial_state == 'failed'"
                       optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="wage" widget="monetary" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Contract (hr.version) Search View -->
    <record id="hr_version_contract_view_search" model="ir.ui.view">
        <field name="name">hr.version.contract.search</field>
        <field name="model">hr.version</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="contract_type_id"/>
                <field name="job_id"/>
                <field name="department_id"/>
                <separator/>
                <filter name="filter_real_contracts" string="Vrais contrats"
                        domain="[('state', '!=', 'draft')]"/>
                <filter name="filter_drafts" string="Brouillons"
                        domain="[('state', '=', 'draft')]"/>
                <separator/>
                <filter name="filter_active" string="Actifs"
                        domain="[('state', '=', 'active')]"/>
                <filter name="filter_pending" string="En attente"
                        domain="[('state', '=', 'pending')]"/>
                <filter name="filter_expired" string="Expires"
                        domain="[('state', '=', 'expired')]"/>
                <separator/>
                <filter name="filter_cdi" string="CDI"
                        domain="[('is_cdd', '=', False)]"/>
                <filter name="filter_cdd" string="CDD"
                        domain="[('is_cdd', '=', True)]"/>
                <separator/>
                <filter string="Employe" name="group_employee" domain="[]" context="{'group_by': 'employee_id'}"/>
                <filter string="Type" name="group_type" domain="[]" context="{'group_by': 'contract_type_id'}"/>
                <filter string="Statut" name="group_state" domain="[]" context="{'group_by': 'state'}"/>
                <filter string="Departement" name="group_department" domain="[]" context="{'group_by': 'department_id'}"/>
            </search>
        </field>
    </record>

    <!-- Contract (hr.version) Form View -->
    <record id="hr_version_contract_view_form" model="ir.ui.view">
        <field name="name">hr.version.contract.form</field>
        <field name="model">hr.version</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <form string="Contrat">
                <header>
                    <!-- Boutons de workflow -->
                    <button name="action_set_pending" type="object"
                            string="Envoyer pour signature" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_sign" type="object"
                            string="Signer le contrat" class="btn-primary"
                            invisible="state != 'pending'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_terminate" type="object"
                            string="Resilier" class="btn-secondary"
                            invisible="state not in ('active', 'pending')"
                            confirm="Etes-vous sur de vouloir resilier ce contrat?"
                            groups="hr.group_hr_manager"/>
                    <!-- Bouton Imprimer -->
                    <button name="action_print_contract" type="object"
                            string="Imprimer" class="btn-secondary"
                            invisible="state == 'draft'" icon="fa-print"/>
                    <!-- Boutons periode essai et renouvellement -->
                    <button name="action_open_trial_wizard" type="object"
                            string="Periode d'essai" class="btn-secondary"
                            invisible="state == 'draft' or not trial_date_end or trial_state == 'confirmed'"
                            groups="hr.group_hr_manager"/>
                    <button name="action_open_renewal_wizard" type="object"
                            string="Renouveler" class="btn-secondary"
                            invisible="state == 'draft' or not is_cdd"
                            groups="hr.group_hr_manager"/>
                    <!-- Statut -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,active"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_avenants" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="state == 'draft'">
                            <field name="avenant_count" widget="statinfo" string="Avenants"/>
                        </button>
                    </div>
                    <!-- Ribbon pour brouillon -->
                    <widget name="web_ribbon" title="Brouillon" bg_color="text-bg-secondary"
                            invisible="state != 'draft'"/>
                    <widget name="web_ribbon" title="Resilie" bg_color="text-bg-danger"
                            invisible="state != 'terminated'"/>
                    <!-- Ribbon periode d'essai -->
                    <field name="trial_warning_level" invisible="1"/>
                    <widget name="web_ribbon" title="Periode d'essai" bg_color="text-bg-info"
                            invisible="trial_warning_level != 'ongoing'"/>
                    <widget name="web_ribbon" title="Fin essai proche!" bg_color="text-bg-warning"
                            invisible="trial_warning_level != 'warning'"/>
                    <widget name="web_ribbon" title="Essai a traiter!" bg_color="text-bg-danger"
                            invisible="trial_warning_level != 'danger'"/>
                    <div class="oe_title">
                        <label for="contract_reference"/>
                        <h1>
                            <field name="contract_reference" placeholder="Numero genere a la confirmation"
                                   readonly="state == 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Employe">
                            <field name="employee_id" required="1"
                                   readonly="state not in ('draft', 'pending')"/>
                            <field name="job_id"/>
                            <field name="department_id"/>
                            <field name="hr_responsible_id" widget="many2one_avatar_user"/>
                        </group>
                        <group string="Type de contrat">
                            <field name="modele_id" options="{'no_create': True}"
                                   readonly="state not in ('draft', 'pending')"/>
                            <field name="contract_type_id"
                                   readonly="state not in ('draft', 'pending')"/>
                            <field name="is_cdd" invisible="1"/>
                            <field name="duration_months" invisible="not is_cdd"/>
                            <field name="renewal_count" readonly="1" invisible="renewal_count == 0"/>
                        </group>
                    </group>
                    <group>
                        <group string="Dates">
                            <field name="date_etablissement"/>
                            <field name="contract_date_start"/>
                            <field name="contract_date_end" invisible="not is_cdd"/>
                        </group>
                        <group string="Periode d'essai">
                            <field name="trial_duration_months"/>
                            <field name="trial_date_end"/>
                            <field name="trial_state" widget="badge"
                                   decoration-info="trial_state == 'pending'"
                                   decoration-warning="trial_state in ('ongoing', 'extended')"
                                   decoration-success="trial_state == 'confirmed'"
                                   decoration-danger="trial_state == 'failed'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Salaire" name="salary">
                            <group>
                                <group>
                                    <field name="currency_id" invisible="1"/>
                                    <label for="wage" string="Salaire de base (mensuel)"/>
                                    <div class="o_row">
                                        <field name="wage" class="o_hr_narrow_field"/>
                                        <span>DA / mois</span>
                                    </div>
                                    <!-- wage_type non implémenté : tous les contrats démarrent en salaire de base -->
                                    <field name="wage_type" invisible="1"/>
                                    <field name="structure_type_id" string="Categorie paie"/>
                                    <separator string="Indemnités journalières"/>
                                    <field name="transport_allowance_enabled" widget="boolean_toggle"/>
                                    <label for="daily_transport_allowance"
                                           invisible="not transport_allowance_enabled"/>
                                    <div class="o_row" invisible="not transport_allowance_enabled">
                                        <field name="daily_transport_allowance" class="o_hr_narrow_field"/>
                                        <span>DA / jour</span>
                                    </div>
                                    <field name="meal_allowance_enabled" widget="boolean_toggle"/>
                                    <label for="daily_meal_allowance"
                                           invisible="not meal_allowance_enabled"/>
                                    <div class="o_row" invisible="not meal_allowance_enabled">
                                        <field name="daily_meal_allowance" class="o_hr_narrow_field"/>
                                        <span>DA / jour</span>
                                    </div>
                                </group>
                                <group>
                                    <field name="resource_calendar_id"/>
                                    <field name="work_schedule_type"/>
                                    <field name="is_overnight_shift"
                                           invisible="work_schedule_type not in ('shift', 'night')"/>
                                    <field name="working_days_per_month"/>
                                    <field name="monthly_hours"/>
                                </group>
                            </group>
                        </page>
                        <page string="Primes" name="primes">
                            <field name="prime_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="prime_type_id"/>
                                    <field name="name"/>
                                    <field name="code" readonly="1"/>
                                    <field name="is_cotisable" readonly="1" widget="boolean"/>
                                    <field name="is_imposable" readonly="1" widget="boolean"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                        <page string="Preavis" name="notice">
                            <group>
                                <group>
                                    <label for="notice_period"/>
                                    <div class="o_row">
                                        <field name="notice_period" class="o_hr_narrow_field"/>
                                        <field name="notice_period_uom"/>
                                    </div>
                                </group>
                            </group>
                        </page>
                        <page string="Articles du contrat" name="articles"
                              invisible="state == 'draft'">
                            <field name="article_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="article_id" options="{'no_create': True}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action for Contracts -->
    <record id="hr_contract_action" model="ir.actions.act_window">
        <field name="name">Contrats</field>
        <field name="res_model">hr.version</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('employee_id', '!=', False)]</field>
        <field name="context">{'search_default_filter_real_contracts': 1}</field>
        <field name="search_view_id" ref="hr_version_contract_view_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('hr_version_contract_view_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('hr_version_contract_view_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Creer un nouveau contrat
            </p>
            <p>
                Les contrats de travail definissent les conditions d'emploi
                (poste, salaire, horaires, periode d'essai, etc.)
            </p>
        </field>
    </record>

</odoo>
