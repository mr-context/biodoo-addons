<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Formulaire hr.version : ajout du taux de congé annuel
    ================================================================ -->
    <record id="hr_version_leave_rate_form" model="ir.ui.view">
        <field name="name">hr.version.leave.rate.form</field>
        <field name="model">hr.version</field>
        <field name="inherit_id" ref="hr_dz_contract.hr_version_contract_view_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='salary']" position="after">
                <page string="Congés" name="leave_dz">
                    <group>
                        <group string="Congé annuel (loi 90-11)">
                            <field name="dz_leave_accrual_rate"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
