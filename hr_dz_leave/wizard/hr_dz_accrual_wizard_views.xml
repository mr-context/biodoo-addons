<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Wizard : Affectation / Backfill congé annuel DZ
    ================================================================ -->
    <record id="hr_dz_accrual_wizard_view_form" model="ir.ui.view">
        <field name="name">hr.dz.accrual.wizard.form</field>
        <field name="model">hr.dz.accrual.wizard</field>
        <field name="arch" type="xml">
            <form string="Affecter congé annuel DZ">
                <group>
                    <group string="Période de pointage">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Options">
                        <field name="backfill"/>
                        <field name="force_recreate"/>
                    </group>
                </group>
                <group string="Employés (vide = tous les actifs)">
                    <field name="employee_ids" widget="many2many_tags" nolabel="1"/>
                </group>
                <group string="Résultat" invisible="not result_message">
                    <field name="result_message" nolabel="1" readonly="1"/>
                </group>
                <footer>
                    <button name="action_create_allocations" type="object"
                            string="Lancer" class="btn-primary"/>
                    <button special="cancel" string="Fermer"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hr_dz_accrual_wizard_action" model="ir.actions.act_window">
        <field name="name">Affecter congé annuel DZ</field>
        <field name="res_model">hr.dz.accrual.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu : Congés → Configuration → Affecter congé annuel DZ -->
    <menuitem id="menu_hr_dz_accrual_wizard"
              name="Affecter congé annuel DZ"
              parent="hr_holidays.menu_hr_holidays_configuration"
              action="hr_dz_accrual_wizard_action"
              sequence="10"
              groups="hr_holidays.group_hr_holidays_manager"/>

</odoo>
