<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_loan_view" model="ir.ui.view">
        <field name="name">res.config.settings.loan</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='contract_work_permit_expiration_notify']" position="after">
                <block title="Prêts salariaux" id="hr_loan_settings">
                    <setting string="Montant maximum autorisé (DA)"
                             help="Montant plafond affiché au portail (informatif)">
                        <field name="loan_max_amount"/>
                    </setting>
                    <setting string="Prêts actifs max / employé"
                             help="Nombre de prêts en cours simultanés autorisés par employé">
                        <field name="loan_max_active"/>
                    </setting>
                    <setting string="Montants suggérés (portail)"
                             help="Boutons de saisie rapide affichés sur le formulaire portail, séparés par des virgules">
                        <field name="loan_amount_presets"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
