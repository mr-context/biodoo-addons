<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ajouter bouton OCR sur fiche employé -->
    <record id="hr_employee_view_form_ocr" model="ir.ui.view">
        <field name="name">hr.employee.form.ocr</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_ocr_wizard" type="object"
                        string="📄 Scanner Document OCR"
                        class="btn-secondary"/>
            </xpath>
        </field>
    </record>
</odoo>
