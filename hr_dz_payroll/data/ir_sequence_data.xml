<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="seq_hr_dz_ats" model="ir.sequence">
        <field name="name">ATS Sequence</field>
        <field name="code">hr.dz.ats</field>
        <field name="prefix">ATS/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
