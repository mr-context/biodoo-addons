        <field name="prefix">301BIS/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_hr_dz_das" model="ir.sequence">
        <field name="name">DAS CNAS Sequence</field>
        <field name="code">hr.dz.das</field>
        <field name="prefix">DAS/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
