<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_employee_view_form_dz_payroll" model="ir.ui.view">
        <field name="name">hr.employee.form.dz.payroll</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">21</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_payslip_analysis"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-bar-chart"
                        groups="payroll.group_payroll_user">
                    <field name="payslip_count" widget="statinfo" string="Analyse paie"/>
                </button>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_open_releve_emoluments" type="object"
                        string="Relevé des Émoluments" class="btn-secondary"
                        groups="hr.group_hr_user"/>
            </xpath>
        </field>
    </record>

</odoo>
