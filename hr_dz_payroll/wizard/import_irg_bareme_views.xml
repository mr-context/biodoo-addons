<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_import_irg_bareme_wizard_form" model="ir.ui.view">
        <field name="name">import.irg.bareme.wizard.form</field>
        <field name="model">import.irg.bareme.wizard</field>
        <field name="arch" type="xml">
            <form string="Importer Barème IRG (CSV DGI)">
                <group>
                    <group string="Informations">
                        <field name="name" placeholder="ex: Barème IRG 2022"/>
                        <field name="company_id"/>
                    </group>
                    <group string="Fichier CSV">
                        <field name="csv_file" widget="binary"
                               filename="csv_filename"
                               placeholder="Sélectionner TABLE_IRG_2022_extracted.csv…"/>
                        <field name="csv_filename" invisible="1"/>
                    </group>
                </group>
                <group>
                    <field name="notes" string="Notes"/>
                </group>
                <div class="alert alert-info" role="alert">
                    <strong>Format CSV attendu :</strong>
                    soumis, irg_general, net_general, irg_particulier, net_particulier<br/>
                    Source : TABLE_IRG_2022_extracted.csv (extrait du PDF officiel DGI)
                </div>
                <footer>
                    <button name="action_import" type="object"
                            string="Importer" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>


</odoo>
