<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Liste : hr.request.type
    ================================================================ -->
    <record id="hr_request_type_view_list" model="ir.ui.view">
        <field name="name">hr.request.type.list</field>
        <field name="model">hr.request.type</field>
        <field name="arch" type="xml">
            <list string="Types de demandes RH">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="team_id"/>
                <field name="requires_dates"/>
                <field name="requires_justification"/>
                <field name="creates_hr_leave"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         Formulaire : hr.request.type
    ================================================================ -->
    <record id="hr_request_type_view_form" model="ir.ui.view">
        <field name="name">hr.request.type.form</field>
        <field name="model">hr.request.type</field>
        <field name="arch" type="xml">
            <form string="Type de demande RH">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archivé" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nom du type de demande"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="icon"/>
                            <field name="color"/>
                        </group>
                        <group string="Configuration">
                            <field name="team_id"/>
                            <field name="requires_dates"/>
                            <field name="requires_justification"/>
                            <field name="creates_hr_leave"/>
                            <field name="leave_type_id"
                                   invisible="not creates_hr_leave"
                                   required="creates_hr_leave"/>
                        </group>
                    </group>
                    <group string="Description portail">
                        <field name="description" nolabel="1"
                               placeholder="Instructions affichées sur le formulaire portail…"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         Action : hr.request.type
    ================================================================ -->
    <record id="hr_request_type_action" model="ir.actions.act_window">
        <field name="name">Types de demandes RH</field>
        <field name="res_model">hr.request.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ================================================================
         Menu : Assistance → Configuration → Types de demandes RH
    ================================================================ -->
    <menuitem id="menu_hr_request_type"
              name="Types de demandes RH"
              parent="assistance.menu_assistance_config"
              action="hr_request_type_action"
              sequence="20"/>

</odoo>
