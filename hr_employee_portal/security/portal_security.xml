<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- ====================================================================
         Règle : un utilisateur portail ne voit que son propre profil employé
    ==================================================================== -->
    <record id="hr_employee_portal_rule" model="ir.rule">
        <field name="name">Employé : accès portail restreint</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ====================================================================
         Règle : un utilisateur portail ne voit que ses propres pointages
    ==================================================================== -->
    <record id="hr_attendance_portal_rule" model="ir.rule">
        <field name="name">Pointage : accès portail restreint</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>


    <!-- ====================================================================
         Règle : un utilisateur portail ne voit que ses propres bulletins
    ==================================================================== -->
    <record id="hr_payslip_portal_rule" model="ir.rule">
        <field name="name">Bulletin de paie : accès portail restreint</field>
        <field name="model_id" search="[('model', '=', 'hr.payslip')]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id), ('state', '=', 'done')]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
