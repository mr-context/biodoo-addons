<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="hr_face_attendance.CheckpointDayMap">
        <div class="o_action d-flex flex-column" style="height: 100vh; padding: 16px;">

            <!-- En-tête -->
            <div class="d-flex align-items-center gap-3 mb-3">
                <button class="btn btn-outline-secondary btn-sm" t-on-click="goBack">
                    <i class="fa fa-arrow-left me-1"/> Retour
                </button>
                <h4 class="mb-0">
                    <i class="fa fa-map-marker me-2 text-primary"/>
                    <t t-esc="props.action.params.employee_name"/> —
                    <t t-esc="props.action.params.period_label"/>
                </h4>
            </div>

            <!-- Légende + compteurs -->
            <div class="d-flex gap-2 mb-2 flex-wrap">
                <span class="badge text-bg-success fs-6">
                    <i class="fa fa-check-circle me-1"/>
                    <t t-esc="state.full_count"/> objectif(s) atteint(s)
                </span>
                <span class="badge text-bg-warning fs-6">
                    <i class="fa fa-adjust me-1"/>
                    <t t-esc="state.partial_count"/> en cours
                </span>
                <span class="badge text-bg-danger fs-6">
                    <i class="fa fa-times-circle me-1"/>
                    <t t-esc="state.none_count"/> non visité(s)
                </span>
            </div>

            <!-- Chargement -->
            <div t-if="state.loading" class="d-flex justify-content-center align-items-center flex-grow-1">
                <div class="text-center">
                    <i class="fa fa-spinner fa-spin fa-3x text-primary mb-3"/>
                    <p class="text-muted">Chargement de l'itinéraire...</p>
                </div>
            </div>

            <!-- Carte -->
            <div t-else="" t-ref="map_container"
                 style="flex: 1; border-radius: 8px; border: 1px solid #dee2e6; min-height: 400px; z-index: 0;"/>
        </div>
    </t>

</templates>
