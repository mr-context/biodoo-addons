<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Liste des logs (vue depuis smart button) ── -->
    <record id="hr_checkpoint_log_view_list" model="ir.ui.view">
        <field name="name">hr.checkpoint.log.list</field>
        <field name="model">hr.checkpoint.log</field>
        <field name="arch" type="xml">
            <list string="Itinéraire — Historique" default_order="check_date desc, check_datetime asc">
                <field name="check_date" string="Date"/>
                <field name="checkpoint_id" string="Checkpoint"/>
                <field name="check_datetime" string="Heure"/>
                <field name="face_confidence" string="Confiance" widget="percentage" optional="show"/>
                <field name="latitude" optional="hide"/>
                <field name="longitude" optional="hide"/>
                <button name="action_open_day_map" type="object"
                        string="Carte période" icon="fa-map-marker"
                        class="btn-sm btn-outline-primary"/>
            </list>
        </field>
    </record>

    <!-- Action depuis smart button -->
    <record id="action_checkpoint_log_employee" model="ir.actions.act_window">
        <field name="name">Itinéraire</field>
        <field name="res_model">hr.checkpoint.log</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="hr_checkpoint_log_view_list"/>
        <field name="context">{'group_by': ['check_date', 'checkpoint_id']}</field>
        <field name="domain">[('employee_id', '=', active_id)]</field>
    </record>

    <!-- Formulaire checkpoint — avec carte Leaflet interactive -->
    <record id="hr_employee_checkpoint_view_form" model="ir.ui.view">
        <field name="name">hr.employee.checkpoint.form</field>
        <field name="model">hr.employee.checkpoint</field>
        <field name="arch" type="xml">
            <form string="Checkpoint">
                <group>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="visits_required"
                               help="Nombre de visites à effectuer sur la période définie sur l'employé."/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                    <group string="Périmètre">
                        <field name="geofence_radius" string="Rayon (m)"/>
                        <field name="geofence_lat" string="Latitude"/>
                        <field name="geofence_lng" string="Longitude"/>
                        <button type="object"
                                name="action_detect_location"
                                string="Détecter ma position GPS"
                                class="btn-outline-primary"
                                icon="fa-crosshairs"/>
                    </group>
                </group>

                <!-- Carte interactive — clic ou drag pour positionner -->
                <div class="mt-3">
                    <widget name="geofence_map"/>
                </div>

                <div class="alert alert-info mt-2" role="alert"
                     invisible="geofence_lat != 0 or geofence_lng != 0">
                    <i class="fa fa-info-circle me-1"/>
                    Cliquez sur la carte pour positionner ce checkpoint,
                    ou utilisez <strong>Détecter ma position GPS</strong>.
                </div>
            </form>
        </field>
    </record>
</odoo>
