<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Compteur dans la home du portail -->
    <template id="portal_my_home_attendance" name="Portail — Présences faciales"
              inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[@id='portal_common_category']" position="inside">
            <t t-if="face_portal_enabled">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="title">Mes présences</t>
                    <t t-set="url">/my/attendance</t>
                    <t t-set="text">Pointer par reconnaissance faciale</t>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </t>
        </xpath>
    </template>

    <!-- Page principale /my/attendance -->
    <template id="portal_attendance" name="Portail — Présences">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Mes présences</t>
            </t>

            <div class="container mt-3">

                <!-- Alerte si pas de visage enregistré -->
                <t t-if="not employee.face_enrolled">
                    <div class="alert alert-warning" role="alert">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        Votre visage n'est pas encore enregistré. Contactez votre RH pour
                        effectuer l'enrollment facial.
                    </div>
                </t>

                <!-- Zone caméra -->
                <t t-if="employee.face_enrolled">
                    <div class="row justify-content-center mb-4">
                        <div class="col-md-6">
                            <div class="card shadow-sm">
                                <div class="card-body text-center p-3">
                                    <!-- Vidéo live -->
                                    <div id="face_camera_container" class="mb-3"
                                         style="position:relative;display:inline-block;max-width:400px;width:100%;">
                                        <video id="face_video"
                                               autoplay="1" playsinline="1" muted="1"
                                               style="width:100%;border-radius:8px;background:#000;display:block;"/>
                                        <!-- Overlay landmarks -->
                                        <canvas id="face_overlay"
                                                style="position:absolute;inset:0;width:100%;height:100%;border-radius:8px;pointer-events:none;"/>
                                        <canvas id="face_canvas" style="display:none;"/>
                                    </div>

                                    <!-- Statut -->
                                    <div id="face_status" class="mb-3">
                                        <span class="badge rounded-pill fs-6"
                                              t-attf-class="bg-{'success' if attendance_state == 'checked_in' else 'secondary'}">
                                            <i t-attf-class="fa fa-{'sign-in' if attendance_state == 'checked_out' else 'sign-out'} me-1"/>
                                            <t t-if="attendance_state == 'checked_in'">En service</t>
                                            <t t-else="">Hors service</t>
                                        </span>
                                    </div>

                                    <!-- GPS status (toujours visible) -->
                                    <t t-if="True">
                                        <div class="mb-2">
                                            <div class="gps-status" id="gps_status">
                                                <span class="gps-dot gps-acquiring" id="gps_dot"/>
                                                <span id="gps_text">Localisation en cours...</span>
                                            </div>
                                            <div class="geofence-bar-wrap mt-1" id="geofence_bar_wrap" style="display:none;">
                                                <div class="geofence-bar" id="geofence_bar" style="width:0%;"/>
                                            </div>
                                        </div>
                                    </t>

                                    <!-- Message résultat -->
                                    <div id="face_result" class="alert d-none" role="alert"/>

                                    <!-- Indicateur de scan -->
                                    <div id="face_scanning" class="text-muted small d-none"/>

                                    <!-- Bouton pointer à nouveau (visible après succès) -->
                                    <div class="mt-3 d-none" id="face_retry_btn">
                                        <button class="btn btn-outline-primary">
                                            <i class="fa fa-camera me-1"/>
                                            Pointer à nouveau
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- Historique semaine -->
                <div class="row">
                    <div class="col-12">
                        <h5 class="mb-3">
                            <i class="fa fa-calendar me-2"/>
                            Cette semaine
                        </h5>
                        <t t-if="week_attendances">
                            <table class="table table-sm table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Entrée</th>
                                        <th>Sortie</th>
                                        <th>Durée</th>
                                        <th>Position</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="week_attendances" t-as="att">
                                        <tr>
                                            <td>
                                                <t t-esc="att.check_in.strftime('%A %d/%m') if att.check_in else ''"/>
                                            </td>
                                            <td>
                                                <t t-esc="att.check_in.strftime('%H:%M') if att.check_in else '—'"/>
                                                <t t-if="att.in_mode == 'face'">
                                                    <span class="badge bg-info ms-1" title="Pointage facial">
                                                        <i class="fa fa-camera"/>
                                                    </span>
                                                </t>
                                            </td>
                                            <td>
                                                <t t-esc="att.check_out.strftime('%H:%M') if att.check_out else '—'"/>
                                            </td>
                                            <td>
                                                <t t-if="att.worked_hours">
                                                    <t t-esc="'%dh%02d' % (int(att.worked_hours), int((att.worked_hours % 1) * 60))"/>
                                                </t>
                                                <t t-else="">En cours</t>
                                            </td>
                                            <td>
                                                <t t-if="att.check_in_latitude and att.check_in_longitude">
                                                    <a t-attf-href="https://www.openstreetmap.org/?mlat=#{att.check_in_latitude}&amp;mlon=#{att.check_in_longitude}#map=17/#{att.check_in_latitude}/#{att.check_in_longitude}"
                                                       target="_blank" class="btn btn-sm btn-outline-secondary" title="Voir sur la carte">
                                                        <i class="fa fa-map-marker"/>
                                                    </a>
                                                </t>
                                                <t t-else="">—</t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <p class="text-muted">Aucune présence cette semaine.</p>
                        </t>
                    </div>
                </div>
            </div>

            <!-- Données pour le JS -->
            <t t-if="employee.face_enrolled">
                <div id="face_config"
                     t-att-data-geofence="'1' if geofence_enabled else '0'"
                     t-att-data-lat="work_location.latitude if work_location else ''"
                     t-att-data-lon="work_location.longitude if work_location else ''"
                     t-att-data-radius="work_location.geofence_radius if work_location else ''"
                     style="display:none;"/>
            </t>
        </t>
    </template>

    <!-- Pas d'autorisation -->
    <template id="portal_not_authorized" name="Portail — Non autorisé">
        <t t-call="portal.portal_layout">
            <div class="container mt-4">
                <div class="alert alert-warning" role="alert">
                    <i class="fa fa-lock me-2"/>
                    Le pointage facial n'est pas activé pour votre compte.
                    Contactez votre responsable RH.
                </div>
            </div>
        </t>
    </template>

    <!-- Pas d'employé lié -->
    <template id="portal_no_employee" name="Portail — Pas d'employé">
        <t t-call="portal.portal_layout">
            <div class="container mt-4">
                <div class="alert alert-warning" role="alert">
                    <i class="fa fa-exclamation-triangle me-2"/>
                    Votre compte utilisateur n'est pas lié à une fiche employé.
                    Contactez votre administrateur RH.
                </div>
            </div>
        </t>
    </template>
</odoo>
