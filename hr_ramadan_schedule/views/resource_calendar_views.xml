<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="resource_calendar_form_ramadan" model="ir.ui.view">
        <field name="name">resource.calendar.form.ramadan</field>
        <field name="model">resource.calendar</field>
        <field name="inherit_id" ref="resource.resource_calendar_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='attendance_ids']" position="before">

                <!-- ── Toggle Mode Ramadan ──────────────────────────── -->
                <div class="d-flex align-items-start gap-2 mb-2">
                    <field name="is_ramadan" widget="boolean_toggle" nolabel="1"/>
                    <div>
                        <strong>Mode Ramadan</strong>
                        <div class="text-muted small">
                            Appliquer des horaires réduits temporairement pendant le Ramadan.
                            Les lignes horaires originales sont conservées.
                        </div>
                    </div>
                </div>

                <!-- ── Bannière active ───────────────────────────────── -->
                <div class="alert alert-warning mb-2" role="alert"
                     invisible="not is_ramadan">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <i class="fa fa-moon-o me-2" title="Mode Ramadan actif"/>
                            <strong>Mode Ramadan actif</strong>
                            <!-- Résumé du mode -->
                            <span class="ms-2 text-muted small"
                                  invisible="ramadan_mode != 'uniform'">
                                — Uniforme
                            </span>
                            <span class="ms-2 text-muted small"
                                  invisible="ramadan_mode != 'gender'">
                                — Par genre (H / F)
                            </span>
                            <!-- Avertissement si pas encore configuré -->
                            <span class="ms-2 text-danger small fw-bold"
                                  invisible="ramadan_hour_to">
                                — Horaires non configurés !
                            </span>
                        </div>
                        <button name="action_open_ramadan_wizard"
                                type="object"
                                string="Configurer les horaires"
                                class="btn-sm btn-warning"
                                icon="fa-cog"/>
                    </div>
                </div>

                <!-- Champs invisibles requis pour les conditions de vue -->
                <field name="ramadan_mode" invisible="1"/>
                <field name="ramadan_hour_to" invisible="1"/>

            </xpath>

        </field>
    </record>

    <!-- ─── 2. Lignes horaires : colonnes Orig. (avant Ramadan) ──────── -->
    <record id="resource_calendar_attendance_list_ramadan" model="ir.ui.view">
        <field name="name">resource.calendar.attendance.list.ramadan</field>
        <field name="model">resource.calendar.attendance</field>
        <field name="inherit_id" ref="resource.view_resource_calendar_attendance_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">

                <!-- Heure de début originale (avant Ramadan) -->
                <field name="original_hour_from"
                       widget="float_time"
                       string="Orig. Début"
                       readonly="1"
                       column_invisible="not parent.is_ramadan"/>

                <!-- Heure de fin originale (avant Ramadan) -->
                <field name="original_hour_to"
                       widget="float_time"
                       string="Orig. Fin"
                       readonly="1"
                       column_invisible="not parent.is_ramadan"/>

            </xpath>
        </field>
    </record>

</odoo>
