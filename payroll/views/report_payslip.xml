<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="report_payslip">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">Bulletin de Paie</h2>
                        <p class="text-center" t-field="o.name" />
                        <table class="table table-sm table-bordered">
                            <tr>
                                <td>
                                    <strong>Nom</strong>
                                </td>
                                <td>
                                    <span t-field="o.employee_id" />
                                </td>
                                <td>
                                    <strong>Fonction</strong>
                                </td>
                                <td>
                                    <span t-field="o.employee_id.job_id" />
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <strong>Matricule</strong>
                                </td>
                                <td>
                                    <span t-field="o.employee_id.identification_id" />
                                </td>
                                <td>
                                    <strong>Département</strong>
                                </td>
                                <td>
                                    <span t-field="o.employee_id.department_id" />
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <strong>N° Bulletin</strong>
                                </td>
                                <td>
                                    <span t-field="o.number" />
                                </td>
                                <td>
                                    <strong>Période</strong>
                                </td>
                                <td>
                                    Du <span t-field="o.date_from" /> au <span t-field="o.date_to" />
                                </td>
                            </tr>
                        </table>

                        <table class="table table-sm table-bordered mt-3">
                            <thead class="table-light">
                                <tr>
                                    <th>Désignation</th>
                                    <th class="text-center">Quantité</th>
                                    <th class="text-end">Montant</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr
                                    t-foreach="o.line_ids.filtered(lambda l: l.appears_on_payslip and l.amount != 0)"
                                    t-as="line"
                                >
                                    <td>
                                        <span t-field="line.name" />
                                    </td>
                                    <td class="text-center">
                                        <span t-field="line.quantity" />
                                    </td>
                                    <td class="text-end">
                                        <span
                                            t-esc="line.amount"
                                            t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'
                                        />
                                    </td>
                                    <td class="text-end">
                                        <span
                                            t-esc="line.total"
                                            t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'
                                        />
                                    </td>
                                </tr>
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end"><strong>Net à Payer</strong></td>
                                    <td class="text-end">
                                        <strong>
                                            <span
                                                t-esc="sum(o.line_ids.filtered(lambda l: l.code == 'NET').mapped('total'))"
                                                t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'
                                            />
                                        </strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <p><strong>Signature employé</strong></p>
                            </div>
                            <div class="col-6 text-center">
                                <p><strong>Signature employeur</strong></p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
