<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="zkteco_connector.FingerprintEnrollDialog">
        <Dialog
            title="props.employeeName ? ('Enrôlement empreinte — ' + props.employeeName) : 'Enrôlement empreinte'"
            size="'md'">

            <div t-attf-class="o_zk_enroll o_zk_enroll_{{state.status}} text-center py-4">

                <!-- ── Empreinte (SVG) + ligne de scan ────────────── -->
                <div class="o_zk_fp_wrap mx-auto">
                    <svg class="o_zk_fp" viewBox="0 0 100 120" fill="none"
                         stroke-linecap="round">
                        <path d="M22 60a28 28 0 0156 0v18"/>
                        <path d="M30 58a20 20 0 0140 0v22a8 8 0 01-16 0"/>
                        <path d="M38 58a12 12 0 0124 0v26"/>
                        <path d="M46 60a4 4 0 018 0v30"/>
                        <path d="M22 78v8"/>
                        <path d="M78 78v10"/>
                        <path d="M30 86v8"/>
                        <path d="M70 88v8"/>
                    </svg>

                    <!-- ligne de scan (uniquement en attente) -->
                    <div class="o_zk_scanline" t-if="state.status === 'waiting'"/>

                    <!-- pastille d'état -->
                    <div class="o_zk_badge" t-if="state.status !== 'waiting'">
                        <i t-if="state.status === 'success'" class="fa fa-check"/>
                        <i t-elif="state.status === 'failed'" class="fa fa-times"/>
                        <i t-else="" class="fa fa-clock-o"/>
                    </div>
                </div>

                <!-- ── Messages d'état ─────────────────────────────── -->
                <div class="mt-4">
                    <t t-if="state.status === 'waiting'">
                        <h4 class="mb-1">Posez le doigt sur la pointeuse…</h4>
                        <p class="text-muted mb-1" t-if="props.fingerLabel">
                            Doigt : <b><t t-esc="props.fingerLabel"/></b>
                        </p>
                        <p class="text-muted small mb-0" t-if="devicesLabel">
                            <t t-esc="devicesLabel"/>
                        </p>
                        <p class="text-muted small mt-2 mb-0">
                            En attente… (<t t-esc="state.elapsed"/>s)
                        </p>
                    </t>

                    <t t-elif="state.status === 'success'">
                        <h4 class="text-success mb-1">Enrôlement réussi ✅</h4>
                        <p class="text-muted mb-0" t-if="fingerName">
                            Empreinte <b><t t-esc="fingerName"/></b> enregistrée.
                        </p>
                    </t>

                    <t t-elif="state.status === 'failed'">
                        <h4 class="text-danger mb-1">Échec de l'enrôlement</h4>
                        <p class="text-muted mb-0"><t t-esc="state.message"/></p>
                    </t>

                    <t t-else="">
                        <h4 class="text-warning mb-1">Pas de réponse de la pointeuse</h4>
                        <p class="text-muted mb-0">
                            Aucun template reçu après <t t-esc="_timeoutSec"/>s.
                            Vérifiez que le device est en ligne, puis réessayez.
                        </p>
                    </t>
                </div>
            </div>

            <t t-set-slot="footer">
                <button t-if="state.status === 'success'"
                        class="btn btn-primary" t-on-click="closeAndReload">
                    Terminer
                </button>
                <button t-else="" class="btn btn-secondary" t-on-click="close">
                    Fermer
                </button>
            </t>
        </Dialog>
    </t>

</templates>